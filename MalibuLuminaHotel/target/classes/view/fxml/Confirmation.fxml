<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.ConfirmationController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="10">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Reservation Confirmed"
                   styleClass="title-label"/>

            <Label text="Thank you for choosing Malibu Lumina Hotel"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="25">

            <VBox alignment="CENTER"
                  spacing="15"
                  prefWidth="750"
                  styleClass="form-card">

                <padding>
                    <Insets top="30"
                            right="30"
                            bottom="30"
                            left="30"/>
                </padding>

                <Label text="Your reservation has been successfully recorded."
                       styleClass="section-label"/>

                <Label text="Billing and payment processing will be completed at the front desk during check-in."
                       wrapText="true"
                       maxWidth="600"
                       styleClass="description-label"/>

                <Label fx:id="reservationNumberLabel"
                       styleClass="field-label"/>

            </VBox>

        </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER">

            <padding>
                <Insets top="20"
                        bottom="25"/>
            </padding>

            <Button text="Return to Home"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="primary-button"
                    onAction="#handleReturnHome"/>

        </HBox>

    </bottom>

</BorderPane>