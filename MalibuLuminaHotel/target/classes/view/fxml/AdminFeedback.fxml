<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Malibu Lumina Hotel"
                   styleClass="title-label"/>

            <Label text="Guest Feedback"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <ScrollPane fitToWidth="true">

            <content>

                <VBox alignment="CENTER"
                      spacing="20">

                    <padding>
                        <Insets top="20"
                                right="20"
                                bottom="20"
                                left="20"/>
                    </padding>

                    <VBox spacing="14"
                          prefWidth="900"
                          styleClass="form-card">

                        <padding>
                            <Insets top="24"
                                    right="24"
                                    bottom="24"
                                    left="24"/>
                        </padding>

                        <Label text="Guest: John Smith"
                               styleClass="section-label"/>

                        <Label text="Reservation ID: R001"
                               styleClass="field-label"/>

                        <Label text="Rating: 5 / 5"
                               styleClass="field-label"/>

                        <Label text="Comment:"
                               styleClass="field-label"/>

                        <Label text="Excellent service and very clean rooms. Staff were friendly and helpful throughout the stay."
                               wrapText="true"
                               styleClass="description-label"/>

                        <Label text="Admin Response:"
                               styleClass="field-label"/>

                        <TextArea promptText="Enter response..."
                                  prefRowCount="3"/>

                        <Button text="Submit Response"
                                prefWidth="180"
                                prefHeight="45"
                                styleClass="primary-button"/>

                    </VBox>

                    <VBox spacing="14"
                          prefWidth="900"
                          styleClass="form-card">

                        <padding>
                            <Insets top="24"
                                    right="24"
                                    bottom="24"
                                    left="24"/>
                        </padding>

                        <Label text="Guest: Emily Davis"
                               styleClass="section-label"/>

                        <Label text="Reservation ID: R002"
                               styleClass="field-label"/>

                        <Label text="Rating: 4 / 5"
                               styleClass="field-label"/>

                        <Label text="Comment:"
                               styleClass="field-label"/>

                        <Label text="Great experience overall. Parking availability could be improved during busy periods."
                               wrapText="true"
                               styleClass="description-label"/>

                        <Label text="Admin Response:"
                               styleClass="field-label"/>

                        <TextArea promptText="Enter response..."
                                  prefRowCount="3"/>

                        <Button text="Submit Response"
                                prefWidth="180"
                                prefHeight="45"
                                styleClass="primary-button"/>

                    </VBox>

                </VBox>

            </content>

        </ScrollPane>

    </center>

    <bottom>

        <HBox alignment="CENTER">

            <padding>
                <Insets top="20"
                        bottom="25"/>
            </padding>

            <Button text="Back to Dashboard"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"/>

        </HBox>

    </bottom>

</BorderPane>