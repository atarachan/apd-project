<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Malibu Lumina Hotel"
                   styleClass="title-label"/>

            <Label text="Reservation Management"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <left>

        <VBox spacing="14"
              prefWidth="290"
              styleClass="option-card">

            <padding>
                <Insets top="24"
                        right="18"
                        bottom="24"
                        left="18"/>
            </padding>

            <VBox spacing="10">

                <Label text="Search Reservation"
                       styleClass="field-label"/>

                <HBox spacing="8">

                    <TextField promptText="Reservation ID or Name"
                               prefWidth="165"
                               prefHeight="38"/>

                    <Button text="Search"
                            prefWidth="77"
                            prefHeight="38"
                            styleClass="primary-button"/>

                </HBox>

            </VBox>

        </VBox>

    </left>

    <center>

        <VBox spacing="18"
              alignment="TOP_LEFT"
              styleClass="option-card">

            <padding>
                <Insets top="24"
                        right="30"
                        bottom="24"
                        left="30"/>
            </padding>

            <Label text="Reservations List"
                   styleClass="section-label"/>

            <VBox spacing="0"
                  styleClass="table-container">

                <HBox spacing="0"
                      styleClass="table-header-row">

                    <Label text="Reservation ID"
                           prefWidth="120"
                           styleClass="table-header"/>

                    <Label text="Main Contact Name"
                           prefWidth="160"
                           styleClass="table-header"/>

                    <Label text="Mobile"
                           prefWidth="120"
                           styleClass="table-header"/>

                    <Label text="Email"
                           prefWidth="180"
                           styleClass="table-header"/>

                    <Label text="Check In Date"
                           prefWidth="110"
                           styleClass="table-header"/>

                    <Label text="Check Out Date"
                           prefWidth="110"
                           styleClass="table-header"/>

                    <Label text="Status"
                           prefWidth="150"
                           styleClass="table-header"/>

                </HBox>

                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="R001"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="John Smith"
                           prefWidth="160"
                           styleClass="table-cell"/>

                    <Label text="555-0123"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="john.smith@email.com"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="2026-07-15"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <Label text="2026-07-20"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <HBox prefWidth="150"
                          alignment="CENTER_LEFT"
                          styleClass="table-cell">

                        <ComboBox prefWidth="130"
                                  value="Pending">

                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Pending"/>
                                    <String fx:value="Checked In"/>
                                    <String fx:value="Checked Out"/>
                                </FXCollections>
                            </items>

                        </ComboBox>

                    </HBox>

                </HBox>

                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="R002"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="Emily Davis"
                           prefWidth="160"
                           styleClass="table-cell"/>

                    <Label text="555-0456"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="emily.d@email.com"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="2026-07-18"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <Label text="2026-07-22"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <HBox prefWidth="150"
                          alignment="CENTER_LEFT"
                          styleClass="table-cell">

                        <ComboBox prefWidth="130"
                                  value="Pending">

                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Pending"/>
                                    <String fx:value="Checked In"/>
                                    <String fx:value="Checked Out"/>
                                </FXCollections>
                            </items>

                        </ComboBox>

                    </HBox>

                </HBox>

                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="R003"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="Michael Brown"
                           prefWidth="160"
                           styleClass="table-cell"/>

                    <Label text="555-0789"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="m.brown@email.com"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="2026-07-21"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <Label text="2026-07-25"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <HBox prefWidth="150"
                          alignment="CENTER_LEFT"
                          styleClass="table-cell">

                        <ComboBox prefWidth="130"
                                  value="Checked In">

                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Pending"/>
                                    <String fx:value="Checked In"/>
                                    <String fx:value="Checked Out"/>
                                </FXCollections>
                            </items>

                        </ComboBox>

                    </HBox>

                </HBox>

                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="R004"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="Sarah Johnson"
                           prefWidth="160"
                           styleClass="table-cell"/>

                    <Label text="555-0321"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="s.johnson@email.com"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="2026-07-25"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <Label text="2026-07-30"
                           prefWidth="110"
                           styleClass="table-cell"/>

                    <HBox prefWidth="150"
                          alignment="CENTER_LEFT"
                          styleClass="table-cell">

                        <ComboBox prefWidth="130"
                                  value="Checked Out">

                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Pending"/>
                                    <String fx:value="Checked In"/>
                                    <String fx:value="Checked Out"/>
                                </FXCollections>
                            </items>

                        </ComboBox>

                    </HBox>

                </HBox>

            </VBox>

        </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="20">

            <padding>
                <Insets top="25"
                        bottom="30"/>
            </padding>

            <Button text="Back to Dashboard"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"/>

            <Button text="Logout"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="primary-button"/>

        </HBox>

    </bottom>

</BorderPane>