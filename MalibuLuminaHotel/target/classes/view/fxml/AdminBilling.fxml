<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.AdminBillingController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Malibu Lumina Hotel"
                   styleClass="title-label"/>

            <Label text="Billing Management"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <left>

        <VBox spacing="12"
              prefWidth="260"
              styleClass="option-card">

            <padding>
                <Insets top="24"
                        right="18"
                        bottom="24"
                        left="18"/>
            </padding>

            <Label text="Search Billing"
                   styleClass="section-label"/>

            <TextField fx:id="searchField"
                       promptText="Bill ID or Guest Name"
                       prefHeight="40"/>

            <Button text="Search"
                    prefWidth="220"
                    prefHeight="45"
                    styleClass="primary-button"
                    onAction="#handleSearch"/>

            <Label text="Payment Status"
                   styleClass="section-label"/>

            <ComboBox prefWidth="220"
                      promptText="Select Status">

                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Pending"/>
                        <String fx:value="Partial"/>
                        <String fx:value="Paid"/>
                    </FXCollections>
                </items>

            </ComboBox>

            <Button text="Update Status"
                    prefWidth="220"
                    prefHeight="45"
                    styleClass="primary-button"
                    onAction="#handleUpdateStatus"/>

        </VBox>

    </left>

    <center>

        <VBox spacing="18"
              styleClass="option-card">

            <padding>
                <Insets top="24"
                        right="30"
                        bottom="24"
                        left="30"/>
            </padding>

            <Label text="Billing Records"
                   styleClass="section-label"/>

            <VBox spacing="0"
                  styleClass="table-container">

                <HBox spacing="0"
                      styleClass="table-header-row">

                    <Label text="Bill ID"
                           prefWidth="120"
                           styleClass="table-header"/>

                    <Label text="Reservation"
                           prefWidth="130"
                           styleClass="table-header"/>

                    <Label text="Guest"
                           prefWidth="180"
                           styleClass="table-header"/>

                    <Label text="Amount"
                           prefWidth="140"
                           styleClass="table-header"/>

                    <Label text="Status"
                           prefWidth="150"
                           styleClass="table-header"/>

                </HBox>


                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="B001"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="R001"
                           prefWidth="130"
                           styleClass="table-cell"/>

                    <Label text="John Smith"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="\$1096.10"
                           prefWidth="140"
                           styleClass="table-cell"/>

                    <Label text="Paid"
                           prefWidth="150"
                           styleClass="table-cell"/>

                </HBox>

                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="B002"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="R002"
                           prefWidth="130"
                           styleClass="table-cell"/>

                    <Label text="Emily Davis"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="\$875.50"
                           prefWidth="140"
                           styleClass="table-cell"/>

                    <Label text="Pending"
                           prefWidth="150"
                           styleClass="table-cell"/>

                </HBox>


                <HBox spacing="0"
                      styleClass="table-data-row">

                    <Label text="B003"
                           prefWidth="120"
                           styleClass="table-cell"/>

                    <Label text="R003"
                           prefWidth="130"
                           styleClass="table-cell"/>

                    <Label text="Michael Brown"
                           prefWidth="180"
                           styleClass="table-cell"/>

                    <Label text="\$1450.00"
                           prefWidth="140"
                           styleClass="table-cell"/>

                    <Label text="Partial"
                           prefWidth="150"
                           styleClass="table-cell"/>

                </HBox>

            </VBox>

        </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="30">

            <padding>
                <Insets top="25"
                        bottom="30"/>
            </padding>

            <Button text="Back to Dashboard"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"
                    onAction="#handleBackToDashboard"/>

            <Button text="Logout"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"
                    onAction="#handleLogout"/>

        </HBox>

    </bottom>

</BorderPane>