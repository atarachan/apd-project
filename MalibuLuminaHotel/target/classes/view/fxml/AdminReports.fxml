<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.AdminReportsController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Reports Management"
                   styleClass="title-label"/>

            <Label text="Generate hotel operational reports"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="25">

            <VBox spacing="18"
                  prefWidth="700"
                  styleClass="form-card">

                <padding>
                    <Insets top="30"
                            right="30"
                            bottom="30"
                            left="30"/>
                </padding>

                <Label text="Select Report Type"
                       styleClass="section-label"/>

                <ComboBox promptText="Choose Report"
                          prefWidth="400">

                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Reservation Report"/>
                            <String fx:value="Revenue Report"/>
                            <String fx:value="Occupancy Report"/>
                            <String fx:value="Guest Feedback Report"/>
                            <String fx:value="Loyalty Program Report"/>
                        </FXCollections>
                    </items>

                </ComboBox>

                <Label text="Available Reports"
                       styleClass="section-label"/>

                <Label text="• Reservation Statistics"
                       styleClass="description-label"/>

                <Label text="• Room Occupancy Summary"
                       styleClass="description-label"/>

                <Label text="• Revenue and Billing Summary"
                       styleClass="description-label"/>

                <Label text="• Guest Satisfaction Summary"
                       styleClass="description-label"/>

                <Label text="• Loyalty Membership Activity"
                       styleClass="description-label"/>

            </VBox>

        </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="25">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Button text="Generate Report"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="primary-button"
                    onAction="#handleGenerateReport"/>

            <Button text="Back to Dashboard"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"
                    onAction="#handleBack"/>

        </HBox>

    </bottom>

</BorderPane>