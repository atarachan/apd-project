<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.AddOnsController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="10">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Enhance Your Stay"
                   styleClass="title-label"/>

            <Label text="Choose any optional services for your reservation."
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="24">

            <VBox spacing="8"
                  maxWidth="700"
                  styleClass="option-card">

                <CheckBox fx:id="breakfastCheckBox" text="Daily Breakfast (+$25/night)"/>

                <Label text="Fresh breakfast served every morning during your stay."
                       wrapText="true"
                       styleClass="description-label"/>

            </VBox>

            <VBox spacing="8"
                  maxWidth="700"
                  styleClass="option-card">

                <CheckBox fx:id="wifiCheckBox" text="Wi-Fi (+$10/night)"/>

                <Label text="High-speed wireless internet available throughout your stay."
                       wrapText="true"
                       styleClass="description-label"/>

            </VBox>

            <VBox spacing="8"
                  maxWidth="700"
                  styleClass="option-card">

                <CheckBox fx:id="parkingCheckBox" text="Parking (+$15/night)"/>

                <Label text="Secure on-site parking available throughout your stay."
                       wrapText="true"
                       styleClass="description-label"/>

            </VBox>

            <VBox spacing="8"
                  maxWidth="700"
                  styleClass="option-card">

                <CheckBox fx:id="spaCheckBox" text="Spa Package (+$80/Reservation)"/>

                <Label text="Enjoy access to our spa and wellness facilities."
                       wrapText="true"
                       styleClass="description-label"/>

            </VBox>

            <VBox alignment="CENTER"
                  spacing="8"
                  prefWidth="720"
                  maxWidth="720"
                  styleClass="image-card">

                <padding>
                    <Insets top="20"
                            right="30"
                            bottom="24"
                            left="30"/>
                </padding>

                <Label text="Add-on Pricing Information"
                       styleClass="section-label"/>

                <Label text="• Breakfast, Wi-Fi and Parking are charged per night."
                       style="-fx-font-size:17px;"/>

                <Label text="• Spa Package is charged once per reservation."
                       style="-fx-font-size:17px;"/>

                <Label text="Prices shown are estimates and will be included in your reservation summary."
                       wrapText="true"
                       textAlignment="CENTER"
                       alignment="CENTER"
                       maxWidth="620"
                       styleClass="description-label"/>

            </VBox>

        </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="30">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Button text="Back"
                    prefWidth="180"
                    prefHeight="50"
                    styleClass="secondary-button"
                    onAction="#handleBack"/>

            <Button text="Continue"
                    prefWidth="180"
                    prefHeight="50"
                    styleClass="primary-button"
                    onAction="#handleContinue"/>

            <Button text="Rules &amp; Regulations"
                    prefWidth="220"
                    prefHeight="50"
                    styleClass="side-button"
                    onAction="#handleRules"/>

        </HBox>

    </bottom>

</BorderPane>
