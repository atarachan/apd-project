<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">
    <left>

        <VBox spacing="14"
              prefWidth="290"
              styleClass="option-card">

            <padding>
                <Insets top="24"
                        right="18"
                        bottom="24"
                        left="18"/>
            </padding>

            <Button text="Reservations"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"/>

            <Button text="Billing"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"/>

            <Button text="Guest Feedback"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"/>

            <Button text="Reports"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"/>

            <Button text="Loyalty Program"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"/>

            <Button text="Waitlist"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"/>

            <VBox spacing="10">
                <Label text="Search Guest / Reservation"
                       styleClass="field-label"/>

                <HBox spacing="8">
                    <TextField promptText="Name or reservation ID"
                               prefWidth="165"
                               prefHeight="38"/>

                    <Button text="Search"
                            prefWidth="77"
                            prefHeight="38"
                            styleClass="primary-button"/>
                </HBox>
            </VBox>

        </VBox>

    </left>

    <center>
        <VBox spacing="20"
              alignment="TOP_CENTER"
              styleClass="option-card">
            <padding>
                <Insets top="30"
                        right="40"
                        bottom="30"
                        left="40"/>
            </padding>

            <Label text="Checkout Process"
                   styleClass="section-label"/>

            <VBox spacing="14" styleClass="form-card" prefWidth="850">
                <padding>
                    <Insets top="20"
                            right="24"
                            bottom="20"
                            left="24"/>
                </padding>

                <Label text="Reservation Information"
                       styleClass="field-label"/>

                <HBox spacing="30">
                    <VBox spacing="8" prefWidth="380">
                        <Label text="Reservation ID: R003" styleClass="helper-label"/>
                        <Label text="Guest Name: Michael Brown" styleClass="helper-label"/>
                        <Label text="Room Type: Deluxe Suite" styleClass="helper-label"/>
                    </VBox>
                    <VBox spacing="8" prefWidth="380">
                        <Label text="Check In: 2026-07-21" styleClass="helper-label"/>
                        <Label text="Check Out: 2026-07-25" styleClass="helper-label"/>
                        <Label text="Total Nights: 4" styleClass="helper-label"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="14" styleClass="form-card" prefWidth="850">
                <padding>
                    <Insets top="20"
                            right="24"
                            bottom="20"
                            left="24"/>
                </padding>

                <Label text="Bill Details"
                       styleClass="field-label"/>

                <HBox spacing="40">
                    <VBox spacing="8" prefWidth="380">
                        <HBox spacing="10">
                            <Label text="Room Charges (4 nights @ 180/night):" prefWidth="250" styleClass="helper-label"/>
                            <Label text="720.00" prefWidth="80" styleClass="helper-label"/>
                        </HBox>

                        <HBox spacing="10">
                            <Label text="Room Service:" prefWidth="250" styleClass="helper-label"/>
                            <Label text="85.00" prefWidth="80" styleClass="helper-label"/>
                        </HBox>

                        <HBox spacing="10">
                            <Label text="Spa Services:" prefWidth="250" styleClass="helper-label"/>
                            <Label text="120.00" prefWidth="80" styleClass="helper-label"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" prefWidth="380">
                        <HBox spacing="10">
                            <Label text="Minibar:" prefWidth="250" styleClass="helper-label"/>
                            <Label text="45.00" prefWidth="80" styleClass="helper-label"/>
                        </HBox>

                        <HBox spacing="10">
                            <Label text="Taxes (13%):" prefWidth="250" styleClass="helper-label"/>
                            <Label text="126.10" prefWidth="80" styleClass="helper-label"/>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox spacing="10">
                    <Label text="Subtotal:" prefWidth="420" styleClass="field-label"/>
                    <Label text="1,096.10" prefWidth="120" styleClass="field-label"/>
                </HBox>
            </VBox>

            <VBox spacing="12" styleClass="form-card" prefWidth="850">
                <padding>
                    <Insets top="20"
                            right="24"
                            bottom="20"
                            left="24"/>
                </padding>

                <Label text="Loyalty Points"
                       styleClass="field-label"/>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Available Points: 2500 (25.00 value)" styleClass="helper-label" prefWidth="320"/>
                    <Label text="Use Points:" styleClass="helper-label"/>
                    <TextField promptText="Enter points to redeem" prefWidth="180" styleClass="input-field"/>
                    <Button text="Apply" prefWidth="90" prefHeight="36" styleClass="primary-button"/>
                </HBox>
            </VBox>

            <VBox spacing="12" styleClass="form-card" prefWidth="850">
                <padding>
                    <Insets top="20"
                            right="24"
                            bottom="20"
                            left="24"/>
                </padding>

                <Label text="Discount"
                       styleClass="field-label"/>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Discount Type:" styleClass="helper-label"/>
                    <ComboBox prefWidth="150" value="None">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="None"/>
                                <String fx:value="Percentage"/>
                                <String fx:value="Fixed Amount"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Label text="Value:" styleClass="helper-label"/>
                    <TextField promptText="Enter discount" prefWidth="140" styleClass="input-field"/>
                    <Button text="Apply" prefWidth="90" prefHeight="36" styleClass="primary-button"/>
                </HBox>
            </VBox>

            <VBox spacing="10" styleClass="form-card" prefWidth="850">
                <padding>
                    <Insets top="20"
                            right="24"
                            bottom="20"
                            left="24"/>
                </padding>

                <HBox spacing="10">
                    <Label text="Total Amount Due:" prefWidth="420" styleClass="section-label"/>
                    <Label text="1,096.10" prefWidth="150" styleClass="section-label"/>
                </HBox>
            </VBox>

            <HBox spacing="18" alignment="CENTER">
                <Button text="Process Checkout"
                        prefWidth="200"
                        prefHeight="50"
                        styleClass="primary-button"/>
                <Button text="Cancel"
                        prefWidth="160"
                        prefHeight="50"
                        styleClass="secondary-button"/>
            </HBox>

        </VBox>
    </center>
    <bottom>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="25"
                        bottom="30"/>
            </padding>

            <Button text="Logout"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"/>

        </VBox>

    </bottom>

</BorderPane>