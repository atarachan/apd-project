<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Malibu Lumina Hotel"
                   styleClass="title-label"/>

            <Label text="Admin Dashboard"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="30">


            <VBox alignment="CENTER"
                  spacing="12">

                <Label text="Search Guest / Reservation"
                       styleClass="section-label"/>

                <HBox alignment="CENTER"
                      spacing="15">

                    <TextField promptText="Enter guest name or reservation ID"
                               prefWidth="340"
                               prefHeight="42"/>

                    <Button text="Search"
                            prefWidth="130"
                            prefHeight="42"
                            styleClass="primary-button"/>

                </HBox>

            </VBox>


            <GridPane alignment="CENTER"
                      hgap="35"
                      vgap="35">

                <Button text="Reservations"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="0"
                        prefWidth="260"
                        prefHeight="90"
                        styleClass="dashboard-button"/>

                <Button text="Billing"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="0"
                        prefWidth="260"
                        prefHeight="90"
                        styleClass="dashboard-button"/>

                <Button text="Guest Feedback"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="1"
                        prefWidth="260"
                        prefHeight="90"
                        styleClass="dashboard-button"/>

                <Button text="Reports"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="1"
                        prefWidth="260"
                        prefHeight="90"
                        styleClass="dashboard-button"/>

                <Button text="Loyalty Program"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="2"
                        prefWidth="260"
                        prefHeight="90"
                        styleClass="dashboard-button"/>

                <Button text="Activity Logs"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="2"
                        prefWidth="260"
                        prefHeight="90"
                        styleClass="dashboard-button"/>

            </GridPane>

        </VBox>

    </center>

    <bottom>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="25"
                        bottom="30"/>
            </padding>

            <Button text="Logout"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"/>

        </VBox>

    </bottom>

</BorderPane>