<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.AdminDashboardController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Malibu Lumina Hotel"
                   styleClass="title-label"/>

            <Label text="Admin Dashboard"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <left>

        <VBox spacing="14"
              prefWidth="290"
              styleClass="option-card">

            <padding>
                <Insets top="24"
                        right="18"
                        bottom="24"
                        left="18"/>
            </padding>

            <Button text="Reservations"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"
                    onAction="#handleReservations"/>

            <Button text="Billing"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"
                    onAction="#handleBilling"/>

            <Button text="Guest Feedback"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"
                    onAction="#handleGuestFeedback"/>

            <Button text="Reports"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"
                    onAction="#handleReports"/>

            <Button text="Loyalty Program"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"
                    onAction="#handleLoyaltyProgram"/>

            <Button text="Waitlist"
                    prefWidth="250"
                    prefHeight="52"
                    styleClass="dashboard-button"
                    onAction="#handleWaitlist"/>

            <VBox spacing="10">
                <Label text="Search Guest / Reservation"
                       styleClass="field-label"/>

                <HBox spacing="8">
                    <TextField fx:id="searchField"
                               promptText="Name or reservation ID"
                               prefWidth="165"
                               prefHeight="38"/>

                    <Button text="Search"
                            prefWidth="77"
                            prefHeight="38"
                            styleClass="primary-button"
                            onAction="#handleSearch"/>
                </HBox>
            </VBox>

        </VBox>

    </left>

    <center>
        <VBox spacing="18"
              alignment="TOP_LEFT"
              styleClass="option-card">
            <padding>
                <Insets top="24"
                        right="30"
                        bottom="24"
                        left="30"/>
            </padding>

            <Label text="Reservations List"
                   styleClass="section-label"/>

            <VBox spacing="0" styleClass="table-container">
                <HBox spacing="0" styleClass="table-header-row">
                    <Label text="Reservation ID" prefWidth="120" styleClass="table-header"/>
                    <Label text="Main Contact Name" prefWidth="160" styleClass="table-header"/>
                    <Label text="Mobile" prefWidth="120" styleClass="table-header"/>
                    <Label text="Email" prefWidth="180" styleClass="table-header"/>
                    <Label text="Check In Date" prefWidth="110" styleClass="table-header"/>
                    <Label text="Check Out Date" prefWidth="110" styleClass="table-header"/>
                    <Label text="Status" prefWidth="150" styleClass="table-header"/>
                </HBox>

                <VBox fx:id="reservationsTableBody" spacing="0"/>
            </VBox>
        </VBox>
    </center>

    <bottom>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="25"
                        bottom="30"/>
            </padding>

            <Button text="Logout"
                    prefWidth="220"
                    prefHeight="55"
                    styleClass="secondary-button"
                    onAction="#handleLogout"/>

        </VBox>

    </bottom>

</BorderPane>
