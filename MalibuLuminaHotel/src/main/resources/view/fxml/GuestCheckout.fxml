<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.GuestCheckoutController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="12">

            <padding>
                <Insets top="25"
                        bottom="25"/>
            </padding>

            <Label text="Malibu Lumina Hotel"
                   styleClass="title-label"/>

            <Label text="Guest Checkout"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="24">

            <padding>
                <Insets top="20"
                        bottom="20"/>
            </padding>

            <VBox spacing="16" styleClass="form-card" prefWidth="750">
                <padding>
                    <Insets top="24"
                            right="28"
                            bottom="24"
                            left="28"/>
                </padding>

                <Label text="Bill Summary"
                       styleClass="section-label"/>

                <HBox spacing="10">
                    <Label text="Subtotal:" prefWidth="500" styleClass="field-label"/>
                    <Label text="CAD 970.00" prefWidth="120" styleClass="field-label"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Taxes (13%):" prefWidth="500" styleClass="field-label"/>
                    <Label text="CAD 126.10" prefWidth="120" styleClass="field-label"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Total Amount:" prefWidth="500" styleClass="section-label"/>
                    <Label text="1,096.10" prefWidth="120" styleClass="section-label"/>
                </HBox>

            </VBox>

            <VBox spacing="14" styleClass="form-card" prefWidth="750">
                <padding>
                    <Insets top="24"
                            right="28"
                            bottom="24"
                            left="28"/>
                </padding>

                <Label text="Loyalty Points"
                       styleClass="section-label"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Available Points: 2,500 (Value: CAD 25.00)" styleClass="field-label"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Points to Use:" styleClass="helper-label"/>
                    <TextField promptText="Enter points amount" prefWidth="200" styleClass="input-field"/>
                    <Button text="Apply Points" prefWidth="120" prefHeight="36" styleClass="primary-button"/>
                </HBox>

                <Label text="Points will be deducted from your total balance."
                       styleClass="helper-label"/>

            </VBox>

            <VBox spacing="16" styleClass="form-card" prefWidth="750">
                <padding>
                    <Insets top="24"
                            right="28"
                            bottom="24"
                            left="28"/>
                </padding>

                <Label text="Payment Options"
                       styleClass="section-label"/>

                <fx:define>
                    <ToggleGroup fx:id="paymentToggleGroup"/>
                </fx:define>

                <RadioButton text="Pay Full Amount (CAD 1,096.10)" 
                             styleClass="check-box"
                             toggleGroup="$paymentToggleGroup"
                             selected="true"/>

                <VBox spacing="12">
                    <RadioButton text="Pay Partial Amount" 
                                 styleClass="check-box"
                                 toggleGroup="$paymentToggleGroup"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <padding>
                            <Insets left="30"/>
                        </padding>
                        <Label text="Amount to Pay:" styleClass="helper-label"/>
                        <TextField promptText="Enter partial amount" prefWidth="200" styleClass="input-field"/>
                    </HBox>

                    <Label text="Note: Remaining balance will be due at checkout."
                           styleClass="helper-label">
                        <padding>
                            <Insets left="30"/>
                        </padding>
                    </Label>
                </VBox>

            </VBox>

            <HBox spacing="18" alignment="CENTER">
                <Button text="Proceed to Payment"
                        prefWidth="220"
                        prefHeight="55"
                        styleClass="primary-button"
                        onAction="#handleProceedToPayment"/>
                <Button text="Cancel"
                        prefWidth="160"
                        prefHeight="55"
                        styleClass="secondary-button"
                        onAction="#handleCancel"/>
            </HBox>

        </VBox>

    </center>

    <bottom>

        <VBox alignment="CENTER">

            <padding>
                <Insets top="20"
                        bottom="25"/>
            </padding>

            <Label text="© Malibu Lumina Hotel"
                   styleClass="footer-label"/>

        </VBox>

    </bottom>

</BorderPane>
