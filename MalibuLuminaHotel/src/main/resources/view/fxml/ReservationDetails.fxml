<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.ReservationDetailsController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="8">

            <padding>
                <Insets top="18"
                    bottom="12"/>
            </padding>

                 <Label text="Guest Information"
                   styleClass="title-label"/>

                 <Label text="Enter guest names and booking main contact"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

         <VBox alignment="CENTER"
            spacing="12">

             <ScrollPane fitToWidth="true"
                   prefWidth="980"
                   maxWidth="980"
                   prefHeight="520"
                   styleClass="form-card">

              <content>
                  <VBox spacing="18"
                     maxWidth="920"
                     styleClass="option-card">

                   <padding>
                    <Insets top="24"
                         right="24"
                         bottom="24"
                         left="24"/>
                   </padding>

                   <Label text="Booking Main Contact"
                       styleClass="section-label"/>

                   <VBox spacing="4">
                    <Label text="Main Contact First Name *"
                        styleClass="field-label"/>
                       <TextField fx:id="firstNameField"
                                  promptText="Required"
                                  styleClass="input-field"/>
                       <Label fx:id="firstNameError" text=""
                              style="-fx-text-fill: #c0392b; -fx-font-size: 12px;"/>
                   </VBox>

                   <VBox spacing="4">
                    <Label text="Main Contact Last Name *"
                        styleClass="field-label"/>
                       <TextField fx:id="lastNameField"
                                  promptText="Required"
                                  styleClass="input-field"/>
                       <Label fx:id="lastNameError" text=""
                              style="-fx-text-fill: #c0392b; -fx-font-size: 12px;"/>
                   </VBox>

                   <VBox spacing="4">
                    <Label text="Main Contact Email *"
                        styleClass="field-label"/>
                       <TextField fx:id="emailField"
                                  promptText="Required"
                                  styleClass="input-field"/>
                       <Label fx:id="emailError" text=""
                              style="-fx-text-fill: #c0392b; -fx-font-size: 12px;"/>
                   </VBox>

                   <VBox spacing="4">
                    <Label text="Main Contact Contact Number *"
                        styleClass="field-label"/>
                       <TextField fx:id="phoneField"
                                  promptText="Required"
                                  styleClass="input-field"/>
                       <Label fx:id="phoneError" text=""
                              style="-fx-text-fill: #c0392b; -fx-font-size: 12px;"/>
                   </VBox>

                  </VBox>
              </content>

             </ScrollPane>

         </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="30">

            <padding>
                <Insets top="16"
                    bottom="18"/>
            </padding>

            <Button text="Back"
                    prefWidth="180"
                    prefHeight="50"
                    styleClass="secondary-button"
                    onAction="#handleBack"/>

            <Button text="Continue"
                    prefWidth="180"
                    prefHeight="50"
                    styleClass="primary-button"
                    onAction="#handleContinue"/>

            <Button text="Rules &amp; Regulations"
                    prefWidth="220"
                    prefHeight="50"
                    styleClass="side-button"
                    onAction="#handleRules"/>

        </HBox>

    </bottom>

</BorderPane>
