<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ca.senecacollege.malibuluminahotel.controller.WelcomeController"
            prefWidth="1280"
            prefHeight="800"
            stylesheets="@../css/style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="8">

            <padding>
                <Insets top="25"
                        bottom="20"/>
            </padding>

            <Label text="Malibu Lumina"
                   styleClass="title-label"/>

            <Label text="Luxury Hotel • Malibu, California"
                   styleClass="subtitle-label"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="24">

            <StackPane
                    maxWidth="850"
                    prefWidth="850"
                    minWidth="850"
                    maxHeight="420"
                    prefHeight="420"
                    minHeight="420"
                    styleClass="image-card">

                <ImageView fx:id="hotelImage"
                           fitWidth="850"
                           fitHeight="420"
                           preserveRatio="false">

                    <image>
                        <Image url="@../images/hotel_welcome.jpg"/>
                    </image>

                </ImageView>

            </StackPane>

            <Label text="Welcome to Malibu Lumina!"
                   styleClass="section-label"/>

            <Label
                    styleClass="description-label"
                    wrapText="true"
                    textAlignment="CENTER"
                    alignment="CENTER"
                    maxWidth="800">

                <text>
                    Reserve your stay in just a few simple steps.
                    Experience luxury accommodations, beautiful ocean views,
                    and exceptional service.
                </text>

            </Label>


            <HBox alignment="CENTER"
                  spacing="20">

                <Button text="Start Reservation"
                        prefWidth="220"
                        prefHeight="55"
                        styleClass="primary-button"/>

                <Button text="View Room Types"
                        prefWidth="220"
                        prefHeight="55"
                        styleClass="secondary-button"/>

                <Button fx:id="rulesButton"
                        text="Rules &amp; Regulations"
                        prefWidth="220"
                        prefHeight="55"
                        styleClass="side-button"/>

            </HBox>

        </VBox>

    </center>

    <bottom>

        <VBox alignment="CENTER"
              spacing="8">

            <padding>
                <Insets top="20"
                        bottom="25"/>
            </padding>

            <Button text="Admin Login"
                    prefWidth="150"
                    prefHeight="38"
                    styleClass="secondary-button"/>

            <Label text="© Malibu Lumina Hotel"
                   styleClass="footer-label"/>

            <Label text="Malibu, California"
                   styleClass="footer-label"/>

        </VBox>

    </bottom>

</BorderPane>